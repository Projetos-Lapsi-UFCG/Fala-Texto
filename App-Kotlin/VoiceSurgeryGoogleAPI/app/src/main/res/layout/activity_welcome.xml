<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <!-- Ícone do app -->
        <ImageView
            android:id="@+id/imgIcon"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@mipmap/ic_launcher"
            android:scaleType="centerInside"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="32dp"/>

        <!-- Título Boas-vindas -->
        <TextView
            android:id="@+id/tvWelcomeTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bem-vindo ao Cirurgia Segura"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            app:layout_constraintTop_toBottomOf="@id/imgIcon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp"/>

        <!-- Subtítulo -->
        <TextView
            android:id="@+id/tvWelcomeSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Documentação clínica por voz · UFCG"
            android:textSize="13sp"
            android:textColor="#3A7DC9"
            app:layout_constraintTop_toBottomOf="@id/tvWelcomeTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="6dp"/>

        <!-- Card: O que é este app? -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardWhatIsApp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#E8F0FB"
            app:layout_constraintTop_toBottomOf="@id/tvWelcomeSubtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="O que é este app?"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#1A3A7C"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Preencha a lista de verificação cirúrgica da OMS usando sua voz, de forma rápida e precisa."
                    android:textSize="13sp"
                    android:textColor="#2A4A6A"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_marginTop="6dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Card: Como utilizar -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardHowToUse"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#E8F0FB"
            app:layout_constraintTop_toBottomOf="@id/cardWhatIsApp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Como utilizar o aplicativo"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#1A3A7C"/>

                <!-- Passo 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp">

                    <TextView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:text="1"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:gravity="center"
                        android:background="@drawable/bg_step_circle"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Aperte o botão 'Falar' e pronuncie a informação referente ao campo mostrado na parte superior da tela."
                        android:textSize="13sp"
                        android:textColor="#2A4A6A"
                        android:lineSpacingMultiplier="1.4"
                        android:layout_marginStart="10dp"/>
                </LinearLayout>

                <!-- Passo 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp">

                    <TextView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:text="2"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:gravity="center"
                        android:background="@drawable/bg_step_circle"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Caso necessário, utilize o teclado virtual para correções ou marcações em campos objetivos."
                        android:textSize="13sp"
                        android:textColor="#2A4A6A"
                        android:lineSpacingMultiplier="1.4"
                        android:layout_marginStart="10dp"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Botão Pular instruções -->
        <Button
            android:id="@+id/btnSkip"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:text="Pular instruções"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1A3A7C"
            android:stateListAnimator="@null"
            app:cornerRadius="16dp"
            app:layout_constraintTop_toBottomOf="@id/cardHowToUse"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="32dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
